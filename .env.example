# Swiss Ephemeris
EPHE_PATH=./ephe
EPHE_MODE=swiss          # swiss | jpl | moshier

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_TITLE=AstroConsultant API
API_VERSION=1.0.0

# Default Ayanamsa (for Vedic calculations)
# Options: LAHIRI, RAMAN, KRISHNAMURTI, FAGAN_BRADLEY, TRUE_CHITRAPAKSHA
DEFAULT_AYANAMSA=LAHIRI

# Default House System (for Western calculations)
# Options: PLACIDUS, KOCH, WHOLE_SIGN, EQUAL, CAMPANUS, REGIOMONTANUS, PORPHYRY
DEFAULT_HOUSE_SYSTEM=PLACIDUS

# Caching
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# Geocoding
GEOCODING_TIMEOUT=5

# MCP Server
MCP_SERVER_NAME=AstroConsultant
MCP_SERVER_VERSION=1.0.0
MCP_FASTAPI_BASE_URL=http://localhost:8000
